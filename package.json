{
    "name": "dsp-seed-finder",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "license": "Apache-2.0",
    "scripts": {
        "extract": "lingui extract --clean",
        "dev": "vite",
        "preview:web": "vite preview --port 5173",
        "preview:native": ".\\target\\release\\dsp_seed.exe",
        "build:web": "vite build",
        "build:browser:dev": "wasm-pack build --target web --dev",
        "build:browser": "wasm-pack build --target web",
        "build:native": "cargo build --release",
        "build": "npm run build:browser && npm run build:native && npm run build:web"
    },
    "dependencies": {
        "@floating-ui/dom": "^1.7.6",
        "@lingui/babel-plugin-lingui-macro": "^6.0.1",
        "@lingui/core": "^6.0.1",
        "@lingui/vite-plugin": "^6.0.1",
        "@solidjs/router": "^0.16.1",
        "clsx": "^2.1.1",
        "exceljs": "^4.4.0",
        "jszip": "^3.10.1",
        "nanoid": "^5.1.11",
        "solid-icons": "^1.2.0",
        "solid-js": "^1.9.12",
        "tiny-emitter": "^2.1.0",
        "typescript": "^5.9.3",
        "vite": "^6.4.2",
        "vite-plugin-solid": "^2.11.12"
    },
    "devDependencies": {
        "@types/node": "^24.12.2",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-solid": "^0.14.5",
        "prettier": "^3.8.3"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.60.2"
    }
}
